# Environment Configuration
# Copy this file to .env.local and update with your values

# GitHub Configuration (for portfolio data)
NEXT_PUBLIC_GITHUB_USERNAME=your_github_username
NEXT_PUBLIC_GITHUB_TOKEN=your_github_token_here

# Mistral AI Configuration (Required for AI-powered chatbot)
MISTRAL_API_KEY=your_mistral_api_key_here

# Supabase Configuration (for chat logging and analytics)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Optional: Local AI Configuration (alternatives to Mistral)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# Optional: OpenAI fallback (if you want to keep it as backup)
OPENAI_API_KEY=your_openai_api_key_here

# Environment
NODE_ENV=development 